{
  "name": "lucide-react-taro",
  "version": "1.5.2",
  "description": "Lucide icon components for Taro with dynamic color support, tree shaking, filled icons, and WeChat miniprogram compatibility",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./icons/*": {
      "types": "./dist/types/icons/*.d.ts",
      "import": "./dist/esm/icons/*.js",
      "require": "./dist/cjs/icons/*.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "fetch-icons": "lucide-react-taro-generate fetch-icons --package-dir .",
    "generate": "lucide-react-taro-generate generate-icons --package-dir .",
    "build:bundle": "lucide-react-taro-generate build-lib --package-dir .",
    "build": "npm run fetch-icons && npm run generate && npm run build:bundle",
    "clean": "rm -rf dist src/icons src/index.ts e2e",
    "prepublishOnly": "npm run build",
    "test": "npm run build && vitest run src/__tests__/Icon.test.tsx src/__tests__/generate.test.ts src/__tests__/strict-props-e2e.test.ts src/__tests__/tree-shaking-e2e.test.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "lucide",
    "icons",
    "taro",
    "react",
    "miniprogram",
    "wechat",
    "weixin",
    "svg",
    "icon",
    "tree-shaking"
  ],
  "author": "",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/louisyoungx/lucide-react-taro.git",
    "directory": "packages/lucide-react-taro"
  },
  "homepage": "https://lucide.rocke.top",
  "bugs": {
    "url": "https://github.com/louisyoungx/lucide-react-taro/issues"
  },
  "peerDependencies": {
    "@tarojs/components": ">=3.0.0",
    "react": ">=16.8.0"
  },
  "devDependencies": {
    "@tarojs/components": "4.1.9",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "^20.0.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/coverage-v8": "4.1.0",
    "commander": "^14.0.0",
    "esbuild": "^0.27.3",
    "fuse.js": "^7.1.0",
    "jsdom": "^28.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "rollup": "^4.59.0",
    "rollup-plugin-dts": "^6.3.0",
    "sharp": "^0.33.0",
    "tsx": "^4.0.0",
    "typescript": "5.9.3",
    "vitest": "4.1.0",
    "@lucide-react-taro/generate": "workspace:*"
  },
  "dependencies": {}
}
